# Copy to .env for local development (optional).
# Docker Compose can use a .env file in the project root for these values.

# Where SQLite and app data are stored
CHAT_DATA_DIR=./data

# Default Ollama connection (seeded into the DB on first run; also editable in Settings)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Local speech-to-text (faster-whisper)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Frontend dev only — leave unset when using Docker or production build
# VITE_API_BASE_URL=
